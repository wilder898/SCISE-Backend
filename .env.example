# BASE DE DATOS — PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/scise_db

# AUTENTICACIÓN — JWT
# Generar SECRET_KEY con: openssl rand -hex 32
SECRET_KEY=tu_clave_secreta_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SERVIDOR — FastAPI / Uvicorn
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# CORS — Frontend Astro
ALLOWED_ORIGINS=http://localhost:4321

# PRIMER USUARIO ADMINISTRADOR (seed inicial)
ADMIN_NOMBRE=Administrador SCISE
ADMIN_CORREO=admin@scise.sena.edu.co
ADMIN_DOCUMENTO=1000000000
ADMIN_PASSWORD=CambiarEstoInmediatamente123!

# ENTORNO (development | production | testing)
ENVIRONMENT=development

